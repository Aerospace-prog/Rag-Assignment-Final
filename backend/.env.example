# Copy this file to .env and fill in your API keys

# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# For local development: Place serviceAccountKey.json in backend/ directory
# For production (Render): Set FIREBASE_SERVICE_ACCOUNT_JSON with the entire JSON content as a single line

# Option 1: Use service account JSON file (local development)
# Place your serviceAccountKey.json file in the backend/ directory

# Option 2: Use environment variable (production deployment)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Optional: Individual Firebase credentials (if not using service account JSON)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
